{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist"
  },
  "include": [
    "./00_Base/src/**/*.ts",
    "./03_Modules/*/src/**/*.ts",
    "./Server/src/**/*.ts"
  ],
  "exclude": ["./dist/**/*", "**/node_modules/**"],
  "references": [
    {
      "path": "./Server"
    }
  ]
}
